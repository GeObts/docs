{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "BasedMining",
  "description": "Mine Bitcoin. Hybrid Lottery Pool. Built for home miners, AI agents, and onchain users.",
  "colors": {
    "primary": "#FF6A00",
    "light": "#FF6A00",
    "dark": "#FF6A00"
  },
  "background": {
