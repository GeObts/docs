              "how-it-works",
              "quickstart"
            ]
          },
          {
            "group": "The Pool",
            "pages": [
              "pool/hybrid-model",
              "pool/comparison"
            ]
          },
          {
            "group": "For Miners",
            "pages": [
              "miners/overview",
              "miners/connect-your-rig",
              "miners/payouts"
            ]
          },
          {
            "group": "For Onchain Users",
            "pages": [
              "onchain/mint-hash",
              "onchain/rewards"
            ]
          },
          {
            "group": "For Agents",
            "pages": [
              "agents/overview"
            ]
          },
          {
            "group": "Dashboard",
            "pages": [
              "dashboard/overview",
              "dashboard/leaderboards",
              "dashboard/your-miner-page"
            ]
          },
          {
            "group": "Calculator",
            "pages": [
              "calculator/overview"
            ]
          },
          {
            "group": "Referrals",
            "pages": [
              "referrals/overview"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "faq",
              "glossary"
            ]
          }
        ]
      }
