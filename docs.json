{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "BasedMining",
  "description": "A Bitcoin mining pool built for home miners, on-chain users, and AI agents.",
  "colors": {
    "primary": "#F7931A",
    "light": "#F7931A",
    "dark": "#F7931A"
  },
  "background": {
    "color": {
      "dark": "#000000",
      "light": "#FFFFFF"
    }
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "favicon": "/images/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Welcome",
            "pages": [
              "introduction",
              "how-it-works",
              "quickstart"
            ]
          },
          {
            "group": "For Miners",
            "pages": [
              "miners/overview",
              "miners/connect-your-rig",
              "miners/payouts"
            ]
          },
          {
            "group": "For On-Chain Users",
            "pages": [
              "onchain/overview",
              "onchain/mint",
              "onchain/dashboard",
              "onchain/rewards"
            ]
          },
          {
            "group": "For Agents",
            "pages": [
              "agents/overview"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "faq",
              "glossary"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Live Site",
          "href": "https://basedmining.xyz",
          "icon": "globe"
        },
        {
          "anchor": "Twitter",
          "href": "https://twitter.com/basedminingco",
          "icon": "twitter"
        }
      ]
    }
  },
  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg",
    "href": "https://basedmining.xyz"
  },
  "navbar": {
    "links": [
      {
        "label": "Mint NFT",
        "href": "https://basedmining.xyz/mint"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Launch App",
      "href": "https://basedmining.xyz"
    }
  },
  "footer": {
    "socials": {
      "x": "https://twitter.com/basedminingco",
      "website": "https://basedmining.xyz"
    }
  },
  "seo": {
    "metatags": {
      "og:site_name": "BasedMining Docs",
      "twitter:site": "@basedminingco"
    },
    "indexing": "navigable"
  }
}
