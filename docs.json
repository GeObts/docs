    "global": {
      "anchors": [
        {
          "anchor": "Live Site",
          "href": "https://basedmining.xyz",
          "icon": "globe"
        },
        {
          "anchor": "Mint Hash",
          "href": "https://basedmining.xyz/mint",
          "icon": "sparkles"
        },
        {
          "anchor": "Dashboard",
          "href": "https://basedmining.xyz/dashboard",
          "icon": "chart-line"
        },
        {
          "anchor": "Twitter",
          "href": "https://twitter.com/basedminingco",
          "icon": "twitter"
        }
      ]
    }
  },
  "logo": {
    "light": "/images/logo-light.svg",
