      "label": "Launch App",
      "href": "https://basedmining.xyz"
    }
  },
  "footer": {
    "socials": {
      "x": "https://twitter.com/basedminingco",
      "website": "https://basedmining.xyz"
    }
  },
  "seo": {
    "metatags": {
      "og:site_name": "BasedMining Docs",
